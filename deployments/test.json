  "html": "<!DOCTYPE html>\n<html lang=\"ja\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>かわい子の画像作成 - My App</title>\n    <style>\n        body {\n            font-family: 'Arial', sans-serif;\n            margin: 0;\n            padding: 0;\n            background: linear-gradient(135deg, #f0f4c3, #c5e1a5);\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            height: 100vh;\n            overflow: hidden;\n            animation: fadeIn 1.5s ease-in-out;\n        }\n\n        h1 {\n            color: #5d4037;\n            margin-bottom: 20px;\n        }\n\n        #image-container {\n            width: 300px;\n            height: 300px;\n            border: 2px dashed #5d4037;\n            border-radius: 15px;\n            display: flex;\n            justify-content: center;\n            align-items: center;\n            background-color: #fff;\n            transition: background-color 0.5s ease;\n        }\n\n        #image-container img {\n            max-width: 100%;\n            max-height: 100%;\n            border-radius: 15px;\n            opacity: 0;\n            animation: fadeIn 1s forwards;\n        }\n\n        #generate-button {\n            padding: 10px 20px;\n            background-color: #5d4037;\n            color: white;\n            border: none;\n            border-radius: 5px;\n            cursor: pointer;\n            transition: background-color 0.3s;\n            font-size: 16px;\n        }\n\n        #generate-button:hover {\n            background-color: #3e2723;\n        }\n\n        @keyframes fadeIn {\n            from { opacity: 0; }\n            to { opacity: 1; }\n        }\n\n        @media (max-width: 480px) {\n            #image-container {\n                width: 80vw;\n                height: 80vw;\n            }\n\n            #generate-button {\n                width: 90%;\n            }\n        }\n    </style>\n</head>\n<body>\n    <h1>かわい子の画像作成</h1>\n    <div id=\"image-container\">\n        <img id=\"generated-image\" src=\"\" alt=\"生成されたかわい子の画像\">\n    </div>\n    <button id=\"generate-button\">画像を生成する</button>\n\n    <script>\n        const imageContainer = document.getElementById('image-container');\n        const generatedImage = document.getElementById('generated-image');\n        const generateButton = document.getElementById('generate-button');\n\n        generateButton.addEventListener('click', async () => {\n            generateButton.innerText = '生成中...';\n            try {\n                const response = await fetch('https://api.example.com/generate-cute-image'); // Replace with your image generation API\n                if (!response.ok) {\n                    throw new Error('画像の生成中にエラーが発生しました。');\n                }\n                const data = await response.json();\n                generatedImage.src = data.imageURL; // Replace with the actual field from your API response\n                generatedImage.onload = () => {\n                    generatedImage.style.opacity = 1; // Fade-in effect\n                };\n            } catch (error) {\n                alert(error.message);\n            } finally {\n                generateButton.innerText = '画像を生成する';\n            }\n        });\n    </script>\n</body>\n</html>",
