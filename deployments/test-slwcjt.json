  "description": "Quick test publish from Pro Editor",
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n  <title>Snake Game</title>\n  <style>\n    body {\n      margin: 0;\n      display: grid;\n      place-items: center;\n      height: 100vh;\n      background: #0f172a;\n      color: #e2e8f0;\n      font-family: system-ui, Arial, sans-serif;\n    }\n    .wrap {\n      text-align: center;\n      user-select: none;\n    }\n    canvas {\n      background: #0b1220;\n      border: 2px solid #334155;\n      border-radius: 12px;\n    }\n    .hud {\n      display: flex;\n      justify-content: center;\n      gap: 18px;\n      margin: 12px 0;\n      font-weight: 600;\n    }\n    button {\n      background: #1d4ed8;\n      border: none;\n      color: white;\n      padding: 10px 16px;\n      border-radius: 10px;\n      cursor: pointer;\n      font-weight: 700;\n    }\n    button:active { transform: translateY(1px); }\n    .hint { margin-top: 10px; color: #94a3b8; font-size: 14px; }\n  </style>\n</head>\n<body>\n  <div class=\"wrap\">\n    <canvas id=\"game\" width=\"420\" height=\"420\" aria-label=\"Snake game canvas\"></canvas>\n    <div class=\"hud\">\n      <div>Score: <span id=\"score\">0</span></div>\n      <div>High: <span id=\"high\">0</span></div>\n    </div>\n    <button id=\"startBtn\">Start</button>\n    <div class=\"hint\">Controls: Arrow Keys / WASD. Press P to pause.</div>\n  </div>\n\n  <script>\n    const canvas = document.getElementById('game');\n    const ctx = canvas.getContext('2d');\n\n    const scoreEl = document.getElementById('score');\n    const highEl = document.getElementById('high');\n    const startBtn = document.getElementById('startBtn');\n\n    const GRID = 21;                 // 21x21 grid\n    const CELL = canvas.width / GRID;\n\n    const COLORS = {\n      bg: '#0b1220',\n      grid: 'rgba(148,163,184,0.08)',\n      snake: '#22c55e',\n      snakeHead: '#34d399',\n      food: '#fb7185',\n      text: '#e2e8f0'\n    };\n\n    let snake, dir, nextDir, food, score, high;\n    let running = false;\n    let paused = false;\n    let timer = null;\n    let speedMs = 95; // lower is faster\n\n    function loadHigh() {\n      high = Number(localStorage.getItem('snake_high') || 0);\n      highEl.textContent = high;\n    }\n\n    function saveHigh() {\n      localStorage.setItem('snake_high', String(high));\n    }\n\n    function randCell() {\n      // Random integer in [0, GRID-1]\n      return Math.floor(Math.random() * GRID);\n    }\n\n    function sameCell(a, b) {\n      return a.x === b.x && a.y === b.y;\n    }\n\n    function spawnFood() {\n      while (true) {\n        const f = { x: randCell(), y: randCell() };\n        const onSnake = snake.some(s => sameCell(s, f));\n        if (!onSnake) return f;\n      }\n    }\n\n    function resetGame() {\n      score = 0;\n      scoreEl.textContent = score;\n      speedMs = 95;\n\n      const mid = Math.floor(GRID / 2);\n      snake = [\n        { x: mid, y: mid },\n        { x: mid - 1, y: mid },\n        { x: mid - 2, y: mid },\n      ];\n\n      dir = { x: 1, y: 0 };      // moving right\n      nextDir = { ...dir };\n      food = spawnFood();\n\n      running = false;\n      paused = false;\n      if (timer) clearInterval(timer);\n      timer = null;\n\n      startBtn.textContent = 'Start';\n    }\n\n    function drawGrid() {\n      ctx.fillStyle = COLORS.bg;\n      ctx.fillRect(0, 0, canvas.width, canvas.height);\n\n      ctx.strokeStyle = COLORS.grid;\n      ctx.lineWidth = 1;\n\n      for (let i = 1; i < GRID; i++) {\n        const p = i * CELL;\n        ctx.beginPath();\n        ctx.moveTo(p, 0);\n        ctx.lineTo(p, canvas.height);\n        ctx.stroke();\n\n        ctx.beginPath();\n        ctx.moveTo(0, p);\n        ctx.lineTo(canvas.width, p);\n        ctx.stroke();\n      }\n    }\n\n    function drawCell(cell, color, isHead = false) {\n      const pad = CELL * 0.18;\n      const x = cell.x * CELL + pad;\n      const y = cell.y * CELL + pad;\n      const size = CELL - pad * 2;\n\n      ctx.fillStyle = color;\n      const r = isHead ? 10 : 7;\n      roundRect(x, y, size, size, r);\n      ctx.fill();\n    }\n\n    // Helper for rounded rectangles\n    function roundRect(x, y, w, h, r) {\n      const rr = Math.min(r, w / 2, h / 2);\n      ctx.beginPath();\n      ctx.moveTo(x + rr, y);\n      ctx.arcTo(x + w, y, x + w, y + h, rr);\n      ctx.arcTo(x + w, y + h, x, y + h, rr);\n      ctx.arcTo(x, y + h, x, y, rr);\n      ctx.arcTo(x, y, x + w, y, rr);\n      ctx.closePath();\n    }\n\n    function draw() {\n      drawGrid();\n\n      // Food\n      drawCell(food, COLORS.food);\n\n      // Snake\n      for (let i = 0; i < snake.length; i++) {\n        const c = snake[i];\n        drawCell(c, i === 0 ? COLORS.snakeHead : COLORS.snake, i === 0);\n      }\n\n      // Optional overlay when paused\n      if (!running && score > 0) {\n        // nothing\n      }\n      if (paused) {\n        ctx.fillStyle = 'rgba(15,23,42,0.6)';\n        ctx.fillRect(0, 0, canvas.width, canvas.height);\n        ctx.fillStyle = COLORS.text;\n        ctx.font = '700 28px system-ui, Arial';\n        ctx.textAlign = 'center';\n        ctx.fillText('Paused', canvas.width / 2, canvas.height / 2);\n        ctx.font = '600 14px system-ui, Arial';\n        ctx.fillText('Press P to resume', canvas.width / 2, canvas.height / 2 + 28);\n      }\n    }\n\n    function gameOver() {\n      running = false;\n      paused = false;\n      if (timer) clearInterval(timer);\n      timer = null;\n\n      if (score > high) {\n        high = score;\n        highEl.textContent = high;\n        saveHigh();\n      }\n\n      startBtn.textContent = 'Restart';\n      ctx.fillStyle = 'rgba(15,23,42,0.72)';\n      ctx.fillRect(0, 0, canvas.width, canvas.height);\n      ctx.fillStyle = COLORS.text;\n      ctx.font = '800 34px system-ui, Arial';\n      ctx.textAlign = 'center';\n      ctx.fillText('Game Over', canvas.width / 2, canvas.height / 2 - 10);\n      ctx.font = '600 16px system-ui, Arial';\n      ctx.fillText(`Score: ${score}`, canvas.width / 2, canvas.height / 2 + 20);\n      ctx.fillText(`Press Restart to play again`, canvas.width / 2, canvas.height / 2 + 45);\n    }\n\n    function step() {\n      if (!running || paused) return;\n\n      // Apply queued direction, but disallow reversing directly\n      if (!(nextDir.x === -dir.x && nextDir.y === -dir.y)) {\n        dir = nextDir;\n      }\n\n      const head = snake[0];\n      const newHead = { x: head.x + dir.x, y: head.y + dir.y };\n\n      // Wall collision\n      if (newHead.x < 0 || newHead.x >= GRID || newHead.y < 0 || newHead.y >= GRID) {\n        draw();\n        gameOver();\n        return;\n      }\n\n      // Self collision\n      if (snake.some(s => s.x === newHead.x && s.y === newHead.y)) {\n        draw();\n        gameOver();\n        return;\n      }\n\n      // Move snake\n      snake.unshift(newHead);\n\n      // Eat food\n      if (sameCell(newHead, food)) {\n        score++;\n        scoreEl.textContent = score;\n\n        // Speed up gradually\n        if (speedMs > 45 && score % 3 === 0) {\n          speedMs -= 5;\n          // restart timer with new speed\n          if (timer) clearInterval(timer);\n          timer = setInterval(step, speedMs);\n        }\n\n        food = spawnFood();\n      } else {\n        // Remove tail\n        snake.pop();\n      }\n\n      draw();\n    }\n\n    function start() {\n      resetGame();\n      running = true;\n      paused = false;\n      startBtn.textContent = 'Restart';\n      draw();\n      timer = setInterval(step, speedMs);\n    }\n\n    function togglePause() {\n      if (!running) return;\n      paused = !paused;\n      startBtn.textContent = paused ? 'Resume' : 'Restart';\n      draw();\n    }\n\n    // Input\n    window.addEventListener('keydown', (e) => {\n      const key = e.key.toLowerCase();\n\n      if (key === 'p') {\n        togglePause();\n        return;\n      }\n\n      const isArrow = ['arrowup', 'arrowdown', 'arrowleft', 'arrowright'].includes(key);\n      const map = {\n        'arrowup':    { x: 0, y: -1 },\n        'w':          { x: 0, y: -1 },\n        'arrowdown':  { x: 0, y: 1 },\n        's':          { x: 0, y: 1 },\n        'arrowleft':  { x: -1, y: 0 },\n        'a':          { x: -1, y: 0 },\n        'arrowright': { x: 1, y: 0 },\n        'd':          { x: 1, y: 0 },\n      };\n\n      if (!map[key]) return;\n\n      e.preventDefault();\n      const nd = map[key];\n\n      // If not running, allow first movement after start\n      nextDir = nd;\n\n      // If starting button not pressed yet, start game on first arrow/WASD\n      // (optional: uncomment if you want auto-start)\n      // if (!running) start();\n    }, { passive: false });\n\n    startBtn.addEventListener('click', () => {\n      // If game is over, restart. If paused, resume.\n      if (!running && score === 0) {\n        start();\n        return;\n      }\n      if (running && paused) {\n        paused = false;\n        startBtn.textContent = 'Restart';\n        draw();\n        return;\n      }\n      // If currently running and not paused, treat as restart\n      start();\n    });\n\n    // Init\n    loadHigh();\n    resetGame();\n    draw();\n  </script>\n</body>\n</html>\n",
